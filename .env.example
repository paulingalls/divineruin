# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# AI Services
ANTHROPIC_API_KEY=your-anthropic-api-key
DEEPGRAM_API_KEY=your-deepgram-api-key
GEMINI_API_KEY=your-gemini-api-key
INWORLD_API_KEY=your-inworld-api-key
INWORLD_WORKSPACE_ID=

# Inworld voice IDs — browse at https://docs.inworld.ai/docs/tts/tts-playground
# Clive — calm British baritone; authoritative narrator
INWORLD_VOICE_DM=Clive
# Hades — commanding, gruff; pragmatic guildmaster
INWORLD_VOICE_TORIN=Hades
# Blake — rich, intimate baritone; warm measured companion
INWORLD_VOICE_KAEL=Blake
# Deborah — warm, peaceful, calm tone; rural deliberate elder
INWORLD_VOICE_YANNA=Deborah
# Olivia — young British female, precise; rapid scholar
INWORLD_VOICE_EMRIS=Olivia
# Mortimer — gravelly aggressive fantasy voice; dwarf blacksmith
INWORLD_VOICE_GRIMJAW=Mortimer
# Mark — energetic rapid-fire delivery; panicked wounded messenger
INWORLD_VOICE_RIDER=Mark
# Naomi — warm grounded female; practical brisk innkeeper
INWORLD_VOICE_MAREN=Naomi
# Tristan — deliberate, controlled, polished; formal investigator
INWORLD_VOICE_VALDRIS=Tristan
# Rupert — resonant commanding British male; god of war and valor
INWORLD_VOICE_GOD_KAELEN=Rupert
# Damon — calm raspy, moody; shadow god who speaks in double meanings
INWORLD_VOICE_GOD_SYRATH=Damon
# Graham — profound authoritative British; ancient lorekeeper god
INWORLD_VOICE_GOD_VEYTHAR=Graham
# Levi — measured, ominous; death god who speaks rarely but with weight
INWORLD_VOICE_GOD_MORTAEN=Levi
# Veronica — intimidating commanding female; fierce nature goddess
INWORLD_VOICE_GOD_THYRA=Veronica
# Loretta — inviting folksy warmth; hearthkeeper goddess
INWORLD_VOICE_GOD_AELORA=Loretta
# Cedric — crisp measured, formal; incorruptible justice god
INWORLD_VOICE_GOD_VALDRIS=Cedric
# Tessa — upbeat adventurous Australian; restless sea goddess
INWORLD_VOICE_GOD_NYTHERA=Tessa
# Brian — friendly encouraging; compassionate healer god
INWORLD_VOICE_GOD_ORENTHEL=Brian
# Victor — ominous sinister; enigmatic unsettling fate god
INWORLD_VOICE_GOD_ZHAEL=Victor

# Auth — generate JWT_SECRET with: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=auth@divineruin.com

# Data — credentials must match docker-compose.yml (defaults: divineruin/divineruin_dev)
DATABASE_URL=postgresql://divineruin:divineruin_dev@localhost:5433/divineruin
REDIS_URL=redis://localhost:6379

# Internal API security — shared secret for agent→server calls (required)
# Generate with: openssl rand -hex 16
INTERNAL_SECRET=change-me-generate-with-openssl-rand-hex-16

# CORS origin — "*" is acceptable for mobile-only; restrict if serving web clients
CORS_ORIGIN=*

# Directory for async activity audio files (absolute path, optional)
ASYNC_AUDIO_DIR=

# Image Generation (optional)
ASSET_IMAGE_DIR=
