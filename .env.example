# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# AI Services
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
GEMINI_API_KEY=
INWORLD_API_KEY=
INWORLD_WORKSPACE_ID=

# Inworld voice IDs (optional — defaults to Inworld stock voices)
INWORLD_VOICE_DM=
INWORLD_VOICE_TORIN=
INWORLD_VOICE_KAEL=
INWORLD_VOICE_YANNA=
INWORLD_VOICE_EMRIS=

# Inworld god voice IDs (optional — defaults to Inworld stock voices)
INWORLD_VOICE_GOD_KAELEN=
INWORLD_VOICE_GOD_SYRATH=
INWORLD_VOICE_GOD_VEYTHAR=
INWORLD_VOICE_GOD_MORTAEN=
INWORLD_VOICE_GOD_THYRA=
INWORLD_VOICE_GOD_AELORA=
INWORLD_VOICE_GOD_VALDRIS=
INWORLD_VOICE_GOD_NYTHERA=
INWORLD_VOICE_GOD_ORENTHEL=
INWORLD_VOICE_GOD_ZHAEL=

# Auth
JWT_SECRET=<random-64-char-hex-string>
RESEND_API_KEY=
RESEND_FROM_EMAIL=auth@divineruin.com

# Data
DATABASE_URL=postgresql://divineruin:divineruin@localhost:5433/divineruin
REDIS_URL=redis://localhost:6379

# Internal API security — shared secret for agent→server push calls
INTERNAL_SECRET=

# CORS origin — defaults to "*" (acceptable for mobile-only; restrict in production if serving web clients)
CORS_ORIGIN=*

# Directory for async activity audio files (absolute path)
ASYNC_AUDIO_DIR=

# Image Generation
ASSET_IMAGE_DIR=
