{
  "name": "divineruin",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "bun run --cwd apps/server dev",
    "dev:mobile": "bun run --cwd apps/mobile start",
    "dev:mobile:ios": "bun run --cwd apps/mobile ios",
    "dev:mobile:android": "bun run --cwd apps/mobile android",
    "migrate": "bun run scripts/migrate.ts",
    "seed": "cd scripts && uv run --project ../apps/agent python seed_content.py",
    "dev:agent": "cd apps/agent && uv run --env-file ../../.env python agent.py dev",
    "typecheck": "tsc --noEmit",
    "test": "bun test --cwd apps/server && bun test --cwd apps/mobile"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48"
}
