#!/usr/bin/env bash
set -e

# Env vars to strip from unit tests so missing mocks are caught locally.
# CI's test-bun job has DATABASE_URL + REDIS_URL (real services) but NOT
# these external API vars — so we match that here.
EXTERNAL_API_VARS=(
  LIVEKIT_URL LIVEKIT_API_KEY LIVEKIT_API_SECRET
  ANTHROPIC_API_KEY DEEPGRAM_API_KEY
  INWORLD_API_KEY INWORLD_WORKSPACE_ID
)

echo "Running pre-push test suite..."

# TypeScript tests — clean env for external services
echo "  Bun tests (server, clean env)..."
(
  for var in "${EXTERNAL_API_VARS[@]}"; do unset "$var"; done
  bun test --cwd apps/server
)

echo "  Bun tests (mobile)..."
bun test --cwd apps/mobile

# Python tests — also strip DATABASE_URL/REDIS_URL since agent tests
# are pure unit tests with no service containers.
echo "  Python tests (agent, clean env)..."
(
  for var in "${EXTERNAL_API_VARS[@]}"; do unset "$var"; done
  unset DATABASE_URL REDIS_URL
  bun run test:python
)

# E2E tests — run in Docker via act, matching CI exactly
# Uses containerized Postgres + Redis so dev DB is never touched.
echo "  E2E tests (act → Docker)..."
act -j test-e2e --no-cache-server --container-architecture linux/amd64 -W .github/workflows/ci.yml

echo "All tests passed."
