#!/usr/bin/env bash
set -e

# Env vars to strip from unit tests so missing mocks are caught locally.
# CI's test-bun job has DATABASE_URL + REDIS_URL (real services) but NOT
# these external API vars — so we match that here.
EXTERNAL_API_VARS=(
  LIVEKIT_URL LIVEKIT_API_KEY LIVEKIT_API_SECRET
  ANTHROPIC_API_KEY DEEPGRAM_API_KEY
  INWORLD_API_KEY INWORLD_WORKSPACE_ID
)

# BASH_TEST=1 stubs the git diff source (env var instead of `git`) and the
# heavy test runners (single `echo TESTS_RAN` marker). Used by the harness
# at .githooks/test-pre-push.sh — see that file for the contract.
if [ "${BASH_TEST:-}" = "1" ]; then
  _get_diff() { printf '%s\n' "${BASH_TEST_DIFF:-}"; }
  _run_tests() { echo "TESTS_RAN"; }
else
  _get_diff() { git diff --name-only "$1" "$2"; }
  _run_tests() {
    echo "Running pre-push test suite..."

    # Validate the hook's own docs-only-skip logic before relying on it.
    # The harness uses BASH_TEST=1 in sub-shells, so it can't recurse here.
    echo "  Pre-push hook self-test..."
    bash "$(dirname "$0")/test-pre-push.sh"

    # Acceptance tests require Docker — hard gate (no silent skip on pre-push).
    echo "  Acceptance prerequisite: Docker..."
    if ! docker info >/dev/null 2>&1; then
      echo "ERROR: Docker must be running for pre-push acceptance tests." >&2
      exit 1
    fi

    # Provision Postgres + Redis for the lanes that need real services (E2E's API
    # server). No-op when DATABASE_URL is already set, so a dev with .env / CI's
    # service vars is unaffected; otherwise it stands up a per-run docker pg+redis on
    # ephemeral ports + migrates + seeds and exports DATABASE_URL/REDIS_URL. Lets the
    # gate run without a sourced .env, and isolates the DB across overlapping runs.
    # Most server bun tests are env-independent, but the test:server lane
    # below runs db.test.ts against the live DB — keep DATABASE_URL exported here
    # or that lazy-Proxy regression test silently skips. (The Python lane unsets
    # these below and uses its own testcontainers.)
    # Combined cleanup: kill every STILL-RUNNING backgrounded lane AND remove the
    # per-run test-env containers via _te_teardown (defined by test-env.sh).
    # bg_pids tracks only un-reaped jobs (reaped PIDs are dropped below so the
    # trap never kills a recycled PID). Initialised + trap registered BEFORE
    # sourcing so a failure mid-provision still tears down; _te_teardown guard
    # tolerates it not existing yet. INT/TERM too so a killed push doesn't leak.
    bg_pids=()
    _cleanup() {
      for pid in "${bg_pids[@]}"; do kill "$pid" 2>/dev/null; done
      command -v _te_teardown >/dev/null 2>&1 && _te_teardown || true
    }
    trap _cleanup EXIT INT TERM

    # shellcheck source=scripts/test-env.sh
    source "$(dirname "$0")/../scripts/test-env.sh"
    # shellcheck source=scripts/lane-utils.sh
    source "$(dirname "$0")/../scripts/lane-utils.sh"

    # Run acceptance in the background so it overlaps the unit + E2E steps.
    ( REQUIRE_DOCKER=1 TESTCONTAINERS_RYUK_DISABLED=true bun run test:acceptance ) &
    acc_pid=$!
    bg_pids+=("$acc_pid")

    # The four bun/python unit lanes are independent — server's db.test.ts uses
    # the provisioned DB, python uses its own testcontainers and unsets DB/REDIS,
    # mobile/shared are env-light — so run them CONCURRENTLY, each in its own env
    # subshell so var scoping can't leak across siblings. Wall-clock drops from
    # sum-of-lanes to max-lane; wait_all_lanes fails the push loud if ANY lane
    # exits non-zero (never swallows an exit code).
    echo "  Bun + Python unit lanes (parallel: server, mobile, shared, python)..."
    unit_specs=()
    # server: test:server isolates db.test.ts (real lazy SQL Proxy) in its own
    # process; keep DATABASE_URL or it silently skips. Strip only the external API
    # vars (matches CI's test-bun env).
    ( for var in "${EXTERNAL_API_VARS[@]}"; do unset "$var"; done; bun run test:server ) &
    p=$!; bg_pids+=("$p"); unit_specs+=("$p:server")
    ( bun test --cwd apps/mobile ) &
    p=$!; bg_pids+=("$p"); unit_specs+=("$p:mobile")
    ( bun test --cwd packages/shared ) &
    p=$!; bg_pids+=("$p"); unit_specs+=("$p:shared")
    # python: unset DB/REDIS too — it uses its own testcontainers.
    ( for var in "${EXTERNAL_API_VARS[@]}"; do unset "$var"; done; unset DATABASE_URL REDIS_URL; bun run test:python ) &
    p=$!; bg_pids+=("$p"); unit_specs+=("$p:python")

    # `if` context suppresses set -e so a failing lane is captured, not aborted-on.
    if wait_all_lanes "${unit_specs[@]}"; then unit_rc=0; else unit_rc=$?; fi
    bg_pids=("$acc_pid")  # unit lanes reaped — drop them from the trap's kill list
    if [ "$unit_rc" -ne 0 ]; then
      echo "ERROR: one or more unit lanes failed." >&2
      exit 1
    fi

    # E2E tests — run locally with Playwright (fast: ~80s) AFTER the unit barrier:
    # it needs the per-run DB, boots its own API/Expo/web servers, and is
    # resource-heavy. reuseExistingServer:false means an overlapping run fails
    # loud on a port conflict rather than silently collapsing onto a shared
    # (cross-killed) server.
    echo "  E2E tests (local Playwright)..."
    (cd e2e && bunx playwright test --reporter=list)

    # Propagate the backgrounded acceptance result. Reap + clear bg_pids BEFORE
    # the failure exit (same pattern as the unit barrier) so the trap never kills
    # the just-reaped acceptance PID.
    echo "  Acceptance tests (waiting)..."
    if wait "$acc_pid"; then acc_rc=0; else acc_rc=$?; fi
    bg_pids=()  # acceptance reaped — trap now only tears down the test-env containers
    if [ "$acc_rc" -ne 0 ]; then
      echo "ERROR: acceptance tests failed." >&2
      exit 1
    fi

    echo "All tests passed."
  }
fi

# --- Docs-only short-circuit ---
# Read pushed-ref list from stdin (pre-push hook protocol: one line per ref
# as `local_ref local_sha remote_ref remote_sha`) and skip the test suite
# when every changed file matches a docs-only pattern. Any error → fall
# through to the full suite (fail-safe).
ZERO_SHA="0000000000000000000000000000000000000000"
DOCS_ONLY=true
CHANGED=""
SAW_REF=false        # any non-empty refspec line seen
ALL_DELETIONS=true   # every seen ref is a deletion (local_sha = ZERO)

while read -r local_ref local_sha remote_ref remote_sha; do
  # A blank read (empty stdin yields one) is not a pushed ref — don't count it.
  if [ -z "${local_ref:-}${local_sha:-}${remote_ref:-}${remote_sha:-}" ]; then
    continue
  fi
  SAW_REF=true
  if [ -z "${local_sha:-}" ] || [ "${local_sha}" = "${ZERO_SHA}" ]; then
    continue  # branch deletion — keeps ALL_DELETIONS true
  fi
  ALL_DELETIONS=false  # a real (non-deletion) ref
  if [ "${remote_sha:-}" = "${ZERO_SHA}" ] || [ -z "${remote_sha:-}" ]; then
    # New branch: diff against the merge-base with origin/main.
    if ! BASE=$(git merge-base "${local_sha}" origin/main 2>/dev/null); then
      DOCS_ONLY=false
      break
    fi
  else
    BASE="${remote_sha}"
  fi
  if ! REF_CHANGED=$(_get_diff "${BASE}" "${local_sha}"); then
    DOCS_ONLY=false
    break
  fi
  CHANGED="${CHANGED}${CHANGED:+$'\n'}${REF_CHANGED}"
done

# Pure branch-deletion push (every ref is a deletion) → nothing to test. Skip
# before the docs/code evaluation so deleting a remote branch doesn't run the
# full gate (previously required --no-verify).
if [ "$SAW_REF" = true ] && [ "$ALL_DELETIONS" = true ]; then
  echo "Branch-deletion push — skipping test suites."
  exit 0
fi

# Empty stdin (no refs to consider) → run tests (safe fallback).
if [ -z "$CHANGED" ]; then
  DOCS_ONLY=false
fi

if [ "$DOCS_ONLY" = true ]; then
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
      *.md|docs/*|.claude/*|memory/*) ;;
      *) DOCS_ONLY=false; break ;;
    esac
  done <<< "$CHANGED"
fi

if [ "$DOCS_ONLY" = true ]; then
  echo "Docs-only push — skipping test suites."
  exit 0
fi

_run_tests
