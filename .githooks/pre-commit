#!/usr/bin/env bash
set -e

# Block .env files from being committed
if git diff --cached --name-only | grep -qE '(^|/)\.env$'; then
  echo "ERROR: .env file detected in staging area."
  exit 1
fi

echo "Running pre-commit lint checks..."

# TypeScript type checking
echo "  TypeScript typecheck (root)..."
bun run typecheck
echo "  TypeScript typecheck (mobile)..."
bun run typecheck:mobile

# ESLint
echo "  ESLint..."
bunx eslint --max-warnings 0 .

# Prettier
echo "  Prettier..."
bunx prettier --check 'apps/**/*.{ts,tsx}' 'packages/**/*.ts'

# Python linting
echo "  Python ruff check..."
bun run lint:python

echo "All lint checks passed."
