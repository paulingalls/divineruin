#!/usr/bin/env bash
set -e

echo "Running pre-commit lint checks..."

# TypeScript type checking
echo "  TypeScript typecheck (root)..."
bun run typecheck
echo "  TypeScript typecheck (mobile)..."
cd apps/mobile && bunx tsc --noEmit && cd ../..

# ESLint
echo "  ESLint..."
bunx eslint --max-warnings 0 .

# Prettier
echo "  Prettier..."
bunx prettier --check 'apps/**/*.{ts,tsx}' 'packages/**/*.ts'

# Python linting
echo "  Python ruff check..."
cd apps/agent
uv run ruff check .
uv run ruff format --check .
cd ../..

echo "All lint checks passed."
